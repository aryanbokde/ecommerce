BETTER_AUTH_SECRET=ffcf8a2dd12706623c8bf2bc6e5b663793a6981a73455b4cdfec9243072a7536
BETTER_AUTH_URL=http://localhost:3000

# ── App (exposed to the browser) ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# XAMPP MariaDB: root user, empty password
DATABASE_URL="mysql://root:@localhost:3306/ecommerce"

# ── Sentry (error tracking) ───────────────────────────────────────────────────
# TODO: get DSN from https://sentry.io → Project → Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# ── Razorpay (payments) — TEST mode ───────────────────────────────────────────
# Dashboard → Settings → API Keys (test mode). Secret is server-only; the key id
# is also exposed to the browser for the Checkout widget.
RAZORPAY_KEY_ID=rzp_test_SwSw4oRQxXC4Ag
RAZORPAY_KEY_SECRET=qU0t54RIuKqIOCZ48I22zbkM
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_SwSw4oRQxXC4Ag
# Dashboard → Settings → Webhooks → (create webhook) → "Secret". NOT the API key secret.
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Mailtrap sandbox — captures mail, does NOT deliver to real inboxes) ─
# EMAIL_PROVIDER=smtp turns on real SMTP sending via nodemailer. On localhost we
# point it at Mailtrap's sandbox: every email lands in the Mailtrap web inbox
# instead of reaching the actual recipient — safe for testing.
EMAIL_PROVIDER=smtp
EMAIL_FROM="MyShop <no-reply@myshop.local>"
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=00b78078cad50e
# SMTP_PASS=c000eb125f6636

# ── Social providers (uncomment when ready) ───────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

